{
	"name": "re-color",
	"description": "Hello World!",
	"author": "jrwnnnn, kcirdneH, Idonowhatnametouse",
	"license": "MIT",
	"main": "main.js",
	"version": "0.0.1",
	"scripts": {
		"dev:vue": "vite",
		"dev:electron": "electron main.js",
		"dev": "concurrently \"npm run dev:vue\" \"npm run dev:electron\"",
		"build": "vite build && electron-builder",
		"preview": "vite preview",
		"typecheck": "vue-tsc --noEmit",
		"test": "vue-tsc --noEmit && npm run build"
	},
	"build": {
		"appId": "com.teamReColor.recolor",
		"productName": "Re:Color Pre-Flight",
		"files": [
			"dist/**/*",
			"main.js"
		],
		"directories": {
			"output": "release"
		},
		"win": {
			"target": [
				"nsis",
				"portable"
			]
		},
		"nsis": {
			"artifactName": "${productName} ${version}-Setup.${ext}"
		},
		"portable": {
			"artifactName": "${productName} ${version}-Portable.${ext}"
		}
	},
	"dependencies": {},
	"devDependencies": {
		"@tailwindcss/vite": "^4.2.4",
		"@types/node": "^24.12.2",
		"@vitejs/plugin-vue": "^6.0.6",
		"@vue/tsconfig": "^0.9.1",
		"concurrently": "^9.2.1",
		"electron": "^41.3.0",
		"electron-builder": "^26.8.1",
		"prettier": "^3.8.3",
		"prettier-plugin-tailwindcss": "^0.7.3",
		"tailwindcss": "^4.2.4",
		"typescript": "~6.0.2",
		"vite": "^8.0.10",
		"vue": "^3.5.32",
		"vue-tsc": "^3.2.7"
	}
}
